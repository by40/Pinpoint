# Public base URL of the deployed site.
# Used for canonical URLs, Open Graph / Twitter image URLs, sitemap, robots,
# and JSON-LD structured data. Set this to your real production domain.
#
# Local dev can leave it unset (defaults to https://pinpointapp.uk), but you MUST
# set it in your production environment or social previews and canonicals will
# point at the wrong host.
NEXT_PUBLIC_SITE_URL=https://pinpointapp.uk

# --- Pre-release password gate (proxy.ts) ---
# When SITE_LOCKED is "true", the whole site is hidden behind a password page.
# Set it to anything else (or remove it) to disable the gate at launch.
# To remove the gate entirely, delete proxy.ts, app/gate/, app/api/gate/,
# components/GateForm.tsx and these three vars.
SITE_LOCKED=true
# The shared password you hand out to previewers.
SITE_PASSWORD=change-me
# A long random opaque string — the auth cookie value once a visitor unlocks.
# Generate one with: openssl rand -hex 32
GATE_TOKEN=change-me-to-a-long-random-string
